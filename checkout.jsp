<html>
<head>
<title>Checkout</title>

<style>

body{
    font-family:Arial;
    background:#f1f3f6;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}


.checkout-box{
    background:white;
    width:350px;
    padding:25px;
    border-radius:6px;
    box-shadow:0 2px 8px rgba(0,0,0,0.1);
}

.checkout-box h2{
    text-align:center;
    margin-bottom:20px;
}

.checkout-box input{
    width:100%;
    padding:10px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:4px;
}


.checkout-box button{
    width:100%;
    background:#fb641b;
    color:white;
    border:none;
    padding:12px;
    font-size:16px;
    cursor:pointer;
    border-radius:4px;
}

.checkout-box button:hover{
    background:#e55a15;
}

</style>

</head>

<body>



</body>
</html>